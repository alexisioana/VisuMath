<!DOCTYPE html>
<html lang="ro">
  <head>
    <%- include('../fragmente/head') %>

    <title>VisuMath – <%= titlu %></title>
    <meta name="keywords" content="eroare, <%= titlu %>, VisuMath">
    <meta name="description" content="<%= text %>">
  </head>

  <body id="top">

    <a href="#top" id="link-top" title="Înapoi la începutul paginii">
      <span id="triunghi">&#9651;</span>
    </a>

    <%- include('../fragmente/header') %>

    <main>
      <div id="grid-pagina">
        <section id="pagina-eroare">
          <h2><%= titlu %></h2>
          <p><%= text %></p>
          <figure>
            <img src="<%= imagine %>" alt="<%= titlu %>" width="600">
            <figcaption>Eroare: <%= titlu %></figcaption>
          </figure>
          <p>
            <a href="/index">← Înapoi la pagina principală</a>
          </p>
        </section>
      </div>
    </main>

    <%- include('../fragmente/footer') %>

  </body>
</html>