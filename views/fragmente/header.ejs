<header>
  <h1>VisuMath - Matematică vizualizată</h1>

  <div class="tema-site">
    <label class="form-label mb-0" for="tema-select">
      <svg class="tema-icon tema-icon-soare" aria-hidden="true" viewBox="0 0 16 16">
        <path d="M8 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
        <path d="M8 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-1 0v-1A.5.5 0 0 1 8 1zm0 12a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-1 0v-1A.5.5 0 0 1 8 13zm7-5a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1 0-1h1a.5.5 0 0 1 .5.5zM3 8a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1 0-1h1A.5.5 0 0 1 3 8zm10.657-5.657a.5.5 0 0 1 0 .707l-.707.707a.5.5 0 1 1-.707-.707l.707-.707a.5.5 0 0 1 .707 0zm-9.9 9.9a.5.5 0 0 1 0 .707l-.707.707a.5.5 0 0 1-.707-.707l.707-.707a.5.5 0 0 1 .707 0zm9.9 1.414a.5.5 0 0 1-.707 0l-.707-.707a.5.5 0 0 1 .707-.707l.707.707a.5.5 0 0 1 0 .707zm-9.9-9.9a.5.5 0 0 1-.707 0l-.707-.707a.5.5 0 0 1 .707-.707l.707.707a.5.5 0 0 1 0 .707z"/>
      </svg>
      <svg class="tema-icon tema-icon-luna" aria-hidden="true" viewBox="0 0 16 16">
        <path d="M6 .278a.77.77 0 0 1 .08.858 7.2 7.2 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.79.79 0 0 1 .81.316.73.73 0 0 1-.031.893A8.35 8.35 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.75.75 0 0 1 6 .278z"/>
      </svg>
    </label>
    <select class="form-select form-select-sm" id="tema-select" aria-label="Alege tema">
      <option value="light">Luminoasa</option>
      <option value="dark">Intunecata</option>
      <option value="ocean">Ocean</option>
      <option value="contrast">Contrast</option>
    </select>
  </div>

  <!-- Checkbox hack pentru hamburger (mobil) -->
  <input type="checkbox" id="nav-toggle" class="nav-toggle-input">
  <label for="nav-toggle" class="hamburger-label" aria-label="Deschide meniul">
    <div class="hamburger-icon">
      <div class="bar bar-1"></div>
      <div class="bar bar-2"></div>
      <div class="bar bar-3"></div>
    </div>
  </label>

  <nav>
    <ul>
      <li>
        <a href="/index">
          <i class="fa-solid fa-house nav-icon"></i>
          <span class="nav-text">Acasă</span>
        </a>
        <ul>
          <li><a href="/index#despre">Despre VisuMath</a></li>
          <li><a href="/index#lectii-disponibile">Lecții disponibile</a></li>
          <li><a href="/index#categorii">Categorii de lecții</a></li>
          <li><a href="/index#evenimente">Evenimente</a></li>
        </ul>
      </li>
      <li>
        <a href="/lectii">
          <i class="fa-solid fa-book-open nav-icon"></i>
          <span class="nav-text">Lecții</span>
        </a>
        <ul>
          <li><a href="/lectii#algebra">Algebră</a></li>
          <li><a href="/lectii#geometrie">Geometrie</a></li>
          <li><a href="/lectii#analiza">Analiză matematică</a></li>
          <li><a href="/lectii#statistica">Statistică</a></li>
        </ul>
      </li>

      <li>
        <a href="/exercitii">
          <i class="fa-solid fa-pencil nav-icon"></i>
          <span class="nav-text">Exerciții</span>
        </a>
      </li>
      <li>
        <a href="/resurse-pagina">
          <i class="fa-solid fa-folder-open nav-icon"></i>
          <span class="nav-text">Resurse</span>
        </a>
      </li>
      <li>
        <!-- ETAPA6-MENIU - subcategorii Produse generate din enum DB -->
        <a href="/produse">
          <i class="fa-solid fa-chart-simple nav-icon"></i>
          <span class="nav-text">Produse</span>
        </a>
        <ul>
          <li><a href="/produse">Toate</a></li>
          <% if (typeof categoriiProduse !== 'undefined') { %>
            <% categoriiProduse.forEach(function(categorie) { %>
              <li><a href="/produse/<%= encodeURIComponent(categorie) %>"><%= categorie %></a></li>
            <% }); %>
          <% } %>
        </ul>
      </li>
      <li>
    <a href="/galerie">
      <i class="fa-solid fa-image nav-icon"></i>
      <span class="nav-text">Galerie</span>
    </a>
</li>
      <li>
        <a href="/despre">
          <i class="fa-solid fa-circle-info nav-icon"></i>
          <span class="nav-text">Despre noi</span>
        </a>
      </li>
    </ul>
  </nav>
</header>
